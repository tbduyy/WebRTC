# ============================================================
# WebRTC Group Call - Configuration
# ============================================================

# Server port
PORT=3000

# ============================================================
# Metered.ca TURN Service (Required for cross-network calls)
# ============================================================
# 1. Sign up at: https://dashboard.metered.ca/signup?tool=turnserver
# 2. Create a new app and get App Name + API Key
# 3. Fill in the values below

METERED_APP_NAME=your_app_name
METERED_API_KEY=your_api_key_here
